// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  email             String          @unique
  name              String?
  createdAt         DateTime        @default(now())
  proStatus         Boolean         @default(false)
  settings          UserSettings?
  tasks             Task[]          @relation("UserTasks")
  projects          Project[]       @relation("UserProjects")
  subscription      UserSubscription?
  sessions          Session[]       @relation("UserSessions")
  journalEntries    JournalEntry[]  @relation("UserJournalEntries")
  cyclicTasks       CyclicTask[]    @relation("UserCyclicTasks")
  trackers          Tracker[]       @relation("UserTrackers")
}

model Project {
  id                String    @id @default(uuid())
  userId            String
  name              String
  description       String?
  color             String?   // Hex color for project identification
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  user              User      @relation("UserProjects", fields: [userId], references: [id], onDelete: Cascade)
  tasks             Task[]    @relation("ProjectTasks")
}

model Task {
  id                String    @id @default(uuid())
  userId            String
  projectId         String?   // Optional link to project
  title             String
  notes             String?
  estimatedPomodoros Int?
  completedPomodoros Int      @default(0)
  status            TaskStatus @default(BACKLOG)
  priority          Priority   @default(MEDIUM)
  createdAt         DateTime  @default(now())
  completedAt       DateTime?
  dueDate           DateTime?
  position          Int?
  
  // Repeat schedule fields
  repeatType        RepeatType?
  repeatInterval    Int?       // For "every N weeks", "monthly on day N", etc.
  repeatDays        String?    // JSON array for days of week (for weekly repeats)
  repeatMonth       Int?       // Month for annual repeats (1-12)
  repeatDay         Int?       // Day for monthly/annual repeats (1-31)
  repeatWeekOfMonth Int?       // For "first Tuesday of month" (1-5, where 5 means last)
  repeatDayOfWeek   Int?       // Day of week for "first Tuesday of month" (0=Sunday, 1=Monday, etc.)
  isTemplate        Boolean   @default(false) // True for the original repeating task
  templateTaskId    String?   // Reference to the original template task
  
  user              User      @relation("UserTasks", fields: [userId], references: [id])
  project           Project?  @relation("ProjectTasks", fields: [projectId], references: [id])
}

model UserSettings {
  userId             String  @id
  focusDuration      Int     @default(25)
  shortBreakDuration Int     @default(5)
  longBreakDuration  Int     @default(15)
  longBreakInterval  Int     @default(4)
  theme              Theme   @default(AUTO)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSubscription {
  id                String            @id @default(uuid())
  userId            String            @unique
  status            SubscriptionStatus @default(FREE_TRIAL)
  type              SubscriptionType?
  level             SubscriptionLevel @default(BASIC)
  planId            String?
  freeTrialExpiresAt DateTime
  stripeCustomerId   String?          @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  startTime DateTime @default(now())
  endTime   DateTime?
  expiresAt DateTime
  duration  Int      // Duration in minutes
  type      String   // "focus" or "break"
  user      User     @relation("UserSessions", fields: [userId], references: [id])
}

model JournalEntry {
  id                String          @id @default(uuid())
  userId            String
  title             String
  content           String
  type              JournalEntryType
  date              DateTime
  mood              JournalMood?
  tags              String[]
  templateUsed      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation("UserJournalEntries", fields: [userId], references: [id], onDelete: Cascade)
}

model CyclicTask {
  id                  String    @id @default(uuid())
  userId              String
  groupName           String
  title               String
  description         String?
  lastCompletedDate   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation("UserCyclicTasks", fields: [userId], references: [id], onDelete: Cascade)
}

model Tracker {
  id          String         @id @default(uuid())
  userId      String
  name        String
  groupName   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  entries     TrackerEntry[]
  user        User           @relation("UserTrackers", fields: [userId], references: [id], onDelete: Cascade)
}

model TrackerEntry {
  id          String    @id @default(uuid())
  trackerId   String
  date        DateTime
  value       Int       // 0-100 representing the intensity
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tracker     Tracker   @relation(fields: [trackerId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  DONE
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum SessionType {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

enum Theme {
  LIGHT
  DARK
  AUTO
}

enum SubscriptionStatus {
  FREE_TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum SubscriptionType {
  MONTHLY
  YEARLY
}

enum SubscriptionLevel {
  BASIC
  PREMIUM
}

enum RepeatType {
  DAILY
  WEEKLY
  MONTHLY
  ANNUALLY
  MONTHLY_BY_WEEKDAY // For "first Tuesday of every month"
}

enum JournalEntryType {
  DAILY
  FREEFORM
  REVIEW
}

enum JournalMood {
  HAPPY
  SAD
  NEUTRAL
  ANGRY
  EXCITED
}